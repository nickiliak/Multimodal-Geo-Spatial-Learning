assert torch.cuda.is_available(), 'CUDA unavailable'
" || {
    echo "CRITICAL: CUDA unavailable in Python environment."
    exit 1
}

echo ">>> Running GeoClip zero-shot notebook..."
uv run --no-sync jupyter nbconvert \
    --to notebook \
    --execute \
